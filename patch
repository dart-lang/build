+              buildState: buildState,
+            ),
+          );
+        } on AssetNotFoundException {
+          continue;
+        } on FileSystemException {
+          continue;
+        }
+        if (currentDigest != originalContent.digest) {
+          updates[id] = ChangeType.MODIFY;
+        }
+      }
+    }
