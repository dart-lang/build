index 0000000000..8a94bf125f
--- /dev/null
+++ b/build_runner/test/integration_tests/output_strategy_test.dart
@@ -0,0 +1,189 @@
+// Copyright (c) 2026, the Dart project authors.  Please see the AUTHORS file
+// for details. All rights reserved. Use of this source code is governed by a
+// BSD-style license that can be found in the LICENSE file.
+
+@Tags(['integration4'])
+library;
+
+import 'package:build_runner/src/logging/build_log.dart';
+import 'package:test/test.dart';
+
+import '../common/common.dart';
+
+void main() async {
+  test('overwrite is the default behavior', () async {
+    final pubspecs = await Pubspecs.load();
+    final tester = BuildRunnerTester(pubspecs);
+
+    tester.writeFixturePackage(FixturePackages.copyBuilder());
+    tester.writePackage(
+      name: 'root_pkg',
+      dependencies: ['build_runner'],
+      pathDependencies: ['builder_pkg'],
+      files: {'web/a.txt': 'a'},
+    );
+
+    // Initial build.
+    final build1 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit',
+    );
+    await build1.expect(BuildLog.successPattern);
+    expect(tester.read('root_pkg/web/a.txt.copy'), 'a');
+
+    // User modifies the output manually!
+    tester.write('root_pkg/web/a.txt.copy', 'User modified a');
+
+    // Trigger rebuild
+    tester.write('root_pkg/web/a.txt', 'b');
+
+    // Default behavior should OVERWRITE without error.
+    final build2 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit',
+    );
+    await build2.expect(BuildLog.successPattern);
+
+    // Note: since input changed, the builder runs and the file is overwritten.
+    expect(tester.read('root_pkg/web/a.txt.copy'), 'b');
+  });
+
+  test('--keep-modified-outputs keeps developer modifications', () async {
+    final pubspecs = await Pubspecs.load();
+    final tester = BuildRunnerTester(pubspecs);
+
+    tester.writeFixturePackage(FixturePackages.copyBuilder());
+    tester.writePackage(
+      name: 'root_pkg',
+      dependencies: ['build_runner'],
+      pathDependencies: ['builder_pkg'],
+      files: {'web/a.txt': 'a'},
+    );
+
+    // Initial build.
+    final build1 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit',
+    );
+    await build1.expect(BuildLog.successPattern);
+    expect(tester.read('root_pkg/web/a.txt.copy'), 'a');
+
+    // Trigger a REBUILD, but without changing the input this time!
+    // We just want to see if a normal build without input changes
+    // will overwrite the user's modifications (it would if overwrite was on,
+    // because overwrite causes AssetTracker to flag the file as MODIFY, triggering\n    // a build?).
+    // Actually, in the first test we proved that overwrite OVERWRITES even if input\n    // didn't change!
+
+    // User modifies the output manually!
+    tester.write('root_pkg/web/a.txt.copy', 'User modified a');
+
+    // So here, we just run a build without input change:
+
+    // With --keep-modified-outputs, it should not overwrite the file because it ignores\n    // the manual edit!
+    final build2 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit --keep-modified-outputs',
+    );
+    await build2.expect(BuildLog.successPattern);
+    expect(tester.read('root_pkg/web/a.txt.copy'), 'User modified a');
+  });
+
+  test('--only-check fails on modified outputs', () async {
+    final pubspecs = await Pubspecs.load();
+    final tester = BuildRunnerTester(pubspecs);
+
+    tester.writeFixturePackage(FixturePackages.copyBuilder());
+    tester.writePackage(
+      name: 'root_pkg',
+      dependencies: ['build_runner'],
+      pathDependencies: ['builder_pkg'],
+      files: {'web/a.txt': 'a'},
+    );
+
+    // Initial build.
+    final build1 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit',
+    );
+    await build1.expect(BuildLog.successPattern);
+    expect(tester.read('root_pkg/web/a.txt.copy'), 'a');
+
+    // Trigger a new build by changing input!
+    tester.write('root_pkg/web/a.txt', 'b');
+
+    // With --only-check, it should fail because the output doesn't match the new expected\n    // output.
+    final build2 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit --only-check',
+    );
+
+    await build2.expect('Verify failed due to Added|Deleted|Modified:');
+    await build2.expect('M web/a.txt.copy');
+    // The build fails!
+    await build2.expect(BuildLog.failurePattern);
+  });
+
+  test('--only-check fails on deleted outputs', () async {
+    final pubspecs = await Pubspecs.load();
+    final tester = BuildRunnerTester(pubspecs);
+
+    tester.writeFixturePackage(FixturePackages.copyBuilder());
+    tester.writePackage(
+      name: 'root_pkg',
+      dependencies: ['build_runner'],
+      pathDependencies: ['builder_pkg'],
+      files: {'web/a.txt': 'a'},
+    );
+
+    // Initial build.
+    final build1 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit',
+    );
+    await build1.expect(BuildLog.successPattern);
+
+    // Trigger a verified build by deleting the generated output
+    tester.delete('root_pkg/web/a.txt.copy');
+
+    final build2 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit --only-check',
+    );
+
+    await build2.expect('Verify failed due to Added|Deleted|Modified:');
+    await build2.expect('D web/a.txt.copy');
+    await build2.expect(BuildLog.failurePattern);
+  });
+
+  test('--only-check fails on added (unexpected) outputs', () async {
+    final pubspecs = await Pubspecs.load();
+    final tester = BuildRunnerTester(pubspecs);
+
+    tester.writeFixturePackage(FixturePackages.copyBuilder());
+    tester.writePackage(
+      name: 'root_pkg',
+      dependencies: ['build_runner'],
+      pathDependencies: ['builder_pkg'],
+      files: {'web/a.txt': 'a'},
+    );
+
+    // Initial build.
+    final build1 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit',
+    );
+    await build1.expect(BuildLog.successPattern);
+
+    // Delete the input to make the output "unexpected" (should be deleted)
+    tester.delete('root_pkg/web/a.txt');
+
+    final build2 = await tester.start(
+      'root_pkg',
+      'dart run build_runner build --force-jit --only-check',
+    );
+
+    await build2.expect('Verify failed due to Added|Deleted|Modified:');
+    await build2.expect('A web/a.txt.copy');
+    await build2.expect(BuildLog.failurePattern);
+  });
+}
